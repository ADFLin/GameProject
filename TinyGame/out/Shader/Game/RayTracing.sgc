uint Hash(inout uint s)
{

#if 1
	s = s * 747796405 + 2891336453;
	uint result = ((s >> ((s >> 28) + 4)) ^ s) * 277803737;
	result = (result >> 22) ^ result;
	return result;
#else
	s ^= 2747636419u;
	s *= 2654435769u;
	s ^= s >> 16;
	s *= 2654435769u;
	s ^= s >> 16;
	s *= 2654435769u;
	return s;
#endif
}

float Random(inout uint seed)
{
	return Hash(seed) / 4294967295.0; // 2^32-1
}

float RandomValueNormalDistribution(inout uint state)
{
	// Thanks to https://stackoverflow.com/a/6178290
	float theta = 2 * 3.1415926 * Random(state);
	float rho = sqrt(-2 * log(Random(state)));
	return rho * cos(theta);
}

// Calculate a random direction
float3 RandomDirection(inout uint state)
{
#if 0
	// Thanks to https://math.stackexchange.com/a/1585996
	float x = RandomValueNormalDistribution(state);
	float y = RandomValueNormalDistribution(state);
	float z = RandomValueNormalDistribution(state);
	return normalize(float3(x, y, z));
#else
	float z = Random(state) * 2.0 - 1.0;
	float a = Random(state) * 2.0 * PI;
	float r = sqrt(max(0.0, 1.0 - z * z));
	float x = r * cos(a);
	float y = r * sin(a);
	return float3(x, y, z);
#endif
}

