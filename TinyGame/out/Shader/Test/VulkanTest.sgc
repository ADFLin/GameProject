#include "Common.sgc"

struct OutputVS
{
	float4 pos : SV_POSITION;
	float3 color : TEXCOORD0;
	float2 uv : TEXCOORD1;
};


#if VERTEX_SHADER

struct InputVS
{
	float2 position : ATTRIBUTE0;
	float2 uv       : ATTRIBUTE1;
	float3 color    : ATTRIBUTE2;
};


float2 Offset;

void MainVS(in InputVS v, out OutputVS outData)
{
	outData.pos = float4(v.position + Offset, 0.0, 1.0);
	outData.color = v.color;
	outData.uv = v.uv;
}
#endif

#if PIXEL_SHADER

Texture2D SamplerColor;
SamplerState SamplerColorSampler;


float4 GlobalColor;

void MainPS(in OutputVS v, out float4 outColor : SV_Target0)
{
	float4 color = SamplerColor.Sample(SamplerColorSampler, v.uv);
	outColor = color * GlobalColor;
}
#endif